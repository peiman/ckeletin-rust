# ckeletin framework tasks
# These recipes are framework-owned. Do not edit — replaced on update.

ckeletin_version := `cat .ckeletin/VERSION`

# SSOT for the upstream identity. The workspace `repository` slug is the upstream
# fingerprint: `just init` rewrites "peiman/ckeletin-rust" to "peiman/<project>"
# throughout the root Cargo.toml, so a root manifest still naming this slug means
# this IS the upstream repo. Mirrors ckeletin-go's go.mod module-path guard
# (repository URL is the Rust analog of a Go module path).
ckeletin_upstream_url := "https://github.com/peiman/ckeletin-rust.git"
ckeletin_upstream_slug := "peiman/ckeletin-rust"

# Show framework version and check for local modifications
ckeletin-health:
    @echo "ckeletin framework v{{ckeletin_version}}"
    @if [ -z "$(git status --porcelain .ckeletin/)" ]; then \
        echo "Status: clean"; \
    else \
        echo "WARNING: .ckeletin/ has local changes (incl. added files) — next update will shadow/ignore them"; \
        git status --porcelain .ckeletin/; \
    fi
    @cargo check --workspace -q && echo "Workspace: compiles" || echo "Workspace: BROKEN"

# Framework quality checks
ckeletin-fmt-check:
    cargo fmt --all -- --check

ckeletin-clippy:
    cargo clippy --workspace --all-targets --all-features -- -D warnings

ckeletin-deny:
    cargo deny check

ckeletin-check: ckeletin-fmt-check ckeletin-clippy ckeletin-deny

# Check if a newer framework version is available
ckeletin-check-update:
    #!/usr/bin/env bash
    set -euo pipefail
    if ! git remote | grep -q ckeletin-upstream; then
        echo "No upstream remote. Run: git remote add ckeletin-upstream {{ckeletin_upstream_url}}"
        exit 0
    fi
    git fetch ckeletin-upstream -q
    LOCAL=$(cat .ckeletin/VERSION)
    REMOTE=$(git show ckeletin-upstream/main:.ckeletin/VERSION 2>/dev/null || echo "unknown")
    if [ "$LOCAL" = "$REMOTE" ]; then
        echo "Framework is up to date (v$LOCAL)"
    else
        echo "Update available: v$LOCAL → v$REMOTE"
        echo "Run: just ckeletin-update"
    fi

# Update framework from upstream
ckeletin-update version="main":
    #!/usr/bin/env bash
    set -euo pipefail
    if grep -q "{{ckeletin_upstream_slug}}" Cargo.toml; then
        echo "This is the {{ckeletin_upstream_slug}} upstream repository itself — framework update does not apply here."
        exit 0
    fi
    if [ -n "$(git status --porcelain .ckeletin/)" ]; then
        echo "Error: .ckeletin/ has uncommitted changes (incl. added files). Commit or revert first."
        exit 1
    fi
    OLD_VERSION=$(cat .ckeletin/VERSION)
    if ! git remote | grep -q ckeletin-upstream; then
        git remote add ckeletin-upstream {{ckeletin_upstream_url}}
    fi
    git fetch ckeletin-upstream
    git checkout ckeletin-upstream/{{version}} -- .ckeletin/
    NEW_VERSION=$(cat .ckeletin/VERSION)
    cargo generate-lockfile
    if ! cargo check --workspace; then
        echo "Error: workspace does not compile after update. Rolling back."
        git checkout HEAD -- .ckeletin/
        cargo generate-lockfile
        exit 1
    fi
    echo ""
    echo "Updated ckeletin framework: v$OLD_VERSION → v$NEW_VERSION"
    echo ""
    git diff HEAD -- .ckeletin/CHANGELOG.md || true
    git add .ckeletin/ Cargo.lock
    git commit -m "chore: update ckeletin framework from v$OLD_VERSION to v$NEW_VERSION"

# Preview update without applying
ckeletin-update-dry-run version="main":
    #!/usr/bin/env bash
    set -euo pipefail
    if grep -q "{{ckeletin_upstream_slug}}" Cargo.toml; then
        echo "This is the {{ckeletin_upstream_slug}} upstream repository itself — framework update does not apply here."
        exit 0
    fi
    if ! git remote | grep -q ckeletin-upstream; then
        git remote add ckeletin-upstream {{ckeletin_upstream_url}}
    fi
    git fetch ckeletin-upstream
    LOCAL=$(cat .ckeletin/VERSION)
    REMOTE=$(git show ckeletin-upstream/{{version}}:.ckeletin/VERSION 2>/dev/null || echo "unknown")
    echo "Current: v$LOCAL → Available: v$REMOTE"
    echo ""
    echo "Files that would change:"
    git diff HEAD..ckeletin-upstream/{{version}} --stat -- .ckeletin/

# Applies the upstream .ckeletin/ to the working tree, runs `cargo check`, then
# restores your committed framework (via a trap, so restoration happens even on
# failure or interrupt). Rust needs no import rewriting — crates are referenced
# by name, not an embedded module path. Mirrors ckeletin-go's
# `task ckeletin:update:check-compatibility`.
# Check if the available framework update compiles against your code (no changes kept)
ckeletin-update-check-compatibility version="main":
    #!/usr/bin/env bash
    set -euo pipefail
    if grep -q "{{ckeletin_upstream_slug}}" Cargo.toml; then
        echo "This is the {{ckeletin_upstream_slug}} upstream repository itself — framework update does not apply here."
        exit 0
    fi
    if [ -n "$(git status --porcelain .ckeletin/)" ]; then
        echo "Error: .ckeletin/ has uncommitted changes (incl. added files). Commit or revert first."
        exit 1
    fi
    if ! git remote | grep -q ckeletin-upstream; then
        git remote add ckeletin-upstream {{ckeletin_upstream_url}}
    fi
    git fetch ckeletin-upstream
    if [ "{{version}}" = "main" ]; then
        CHECKOUT_REF="ckeletin-upstream/main"
    else
        git fetch ckeletin-upstream "{{version}}"
        CHECKOUT_REF="FETCH_HEAD"
    fi
    if [ -z "$(git diff --stat HEAD "$CHECKOUT_REF" -- .ckeletin/)" ]; then
        echo "Framework is already up to date — nothing to check."
        exit 0
    fi
    # Restore the committed framework no matter how we exit. .ckeletin/ is clean
    # (checked above), so `git checkout HEAD` is a reliable, interrupt-safe undo.
    restore() { git checkout HEAD -- .ckeletin/ && cargo generate-lockfile; }
    trap restore EXIT
    git checkout "$CHECKOUT_REF" -- .ckeletin/
    cargo generate-lockfile
    echo "Checking compatibility with framework update ({{version}})..."
    set +e
    CHECK_OUTPUT=$(cargo check --workspace 2>&1)
    CHECK_RESULT=$?
    set -e
    if [ "$CHECK_RESULT" -eq 0 ]; then
        echo "Compatible — safe to update."
        echo ""
        echo "Changes available:"
        git diff --stat HEAD "$CHECKOUT_REF" -- .ckeletin/
        echo ""
        echo "Run: just ckeletin-update"
    else
        echo "Incompatible — cargo check failed against the update:"
        echo "$CHECK_OUTPUT"
        echo ""
        echo "Review the errors above before running just ckeletin-update."
        exit 1
    fi

# Run conformance generator (hermetic: reads the committed vendored spec, no network)
conform *ARGS:
    cargo run -p ckeletin-conform -q -- {{ARGS}}

# Refresh the vendored spec snapshot from upstream (maintainer action). Fetches
# the latest requirements.json, rewrites conformance/requirements.json — then
# review the diff and reconcile conformance-mapping.toml + the spec_version.
conform-refresh:
    cargo run -p ckeletin-conform -q -- --refresh

# Regenerate the published conformance report (CKSPEC-ENF-010). The committed
# conformance-report.json is the deterministic artifact the spec-repo aggregator
# fetches; `just conform` fails if it drifts from conformance-mapping.toml, so
# run this after editing the mapping and commit the result.
conform-report:
    cargo run -p ckeletin-conform -q -- --report
